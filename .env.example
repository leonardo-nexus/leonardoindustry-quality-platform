# Copia in .env.local e compila i valori reali

# Supabase project URL (es. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon key pubblica (sicura lato client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key - SOLO server-side, mai esporre al browser
SUPABASE_SERVICE_ROLE_KEY=

# Project ref (es. xxxxxxxxxxxx, parte iniziale del project URL)
SUPABASE_PROJECT_REF=

# Connection string PostgreSQL diretta (opzionale - serve per migrations CLI)
DATABASE_URL=
